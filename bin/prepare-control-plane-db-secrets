#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
Usage: bin/prepare-control-plane-db-secrets APP_NAME --org CPLN_ORG

Creates app-scoped MySQL and Mongo dictionary secrets with random passwords if
they do not already exist. Existing secrets are left unchanged because rotating
database initialization passwords after a stateful database has booted can
desynchronize the workload secret from the initialized database user.
USAGE
}

if [ "$#" -ne 3 ] || [ "${2:-}" != "--org" ]; then
  usage >&2
  exit 1
fi

app_name="$1"
org="$3"

if [ -z "${CPLN_TOKEN:-}" ]; then
  echo "CPLN_TOKEN must be set so cpln can create Control Plane secrets." >&2
  exit 1
fi

random_password() {
  openssl rand -hex 32
}

error_exit() {
  echo "$1" >&2
  exit 1
}

secret_exists() {
  local secret_name="$1"
  cpln secret get "$secret_name" --org "$org" >/dev/null 2>&1
}

verify_existing_secret() {
  local secret_name="$1"
  local secret_payload

  if ! secret_payload="$(cpln secret reveal "$secret_name" --org "$org" --output json 2>/dev/null)"; then
    error_exit "Secret ${secret_name} exists but could not be revealed for placeholder validation."
  fi

  if [[ "$secret_payload" == *"replace-with-real"* ]] || [[ "$secret_payload" == *"the_password"* ]]; then
    error_exit "Secret ${secret_name} still contains public placeholder database credentials. Rotate the database user password in-place or recreate the app database volume and secret before deploying."
  fi
}

create_mysql_secret() {
  local secret_name="${app_name}-mysql"

  if secret_exists "$secret_name"; then
    verify_existing_secret "$secret_name"
    echo "Secret ${secret_name} already exists; leaving database credentials unchanged."
    return
  fi

  cpln secret create-dictionary \
    --org "$org" \
    --name "$secret_name" \
    --entry database=gumroad_demo \
    --entry username=gumroad \
    --entry "password=$(random_password)" \
    --entry "root_password=$(random_password)"
}

create_mongo_secret() {
  local secret_name="${app_name}-mongo"

  if secret_exists "$secret_name"; then
    verify_existing_secret "$secret_name"
    echo "Secret ${secret_name} already exists; leaving database credentials unchanged."
    return
  fi

  cpln secret create-dictionary \
    --org "$org" \
    --name "$secret_name" \
    --entry username=gumroad \
    --entry "password=$(random_password)"
}

create_mysql_secret
create_mongo_secret
